<?xml version="1.0" encoding="UTF-8"?>

<!-- OfficeLabs Modern Theme (Dark Mode — Dracula/Midnight Blue)
     Accent: Teal #2DD4BF (brand)
     Surfaces: Dracula (#1A1B26, #1A1A1A, #2A2A2A, #3A3A3A)
     Borders: Blue-tinted (#3A3A3A)
     Text: Dracula (#FFFFFF, #FFFFFF, #777777)
     Rounded corners (6px buttons, 15px toggles)
-->

<widgets>
    <style>
        <!-- Surfaces — VS Code Dracula palette -->
        <faceColor value="#1A1A1A"/>
        <windowColor value="#0F0F0F"/>
        <dialogColor value="#1A1A1A"/>
        <dialogTextColor value="#FFFFFF"/>
        <workspaceColor value="#1A1A1A"/>

        <!-- Text -->
        <windowTextColor value="#FFFFFF"/>
        <buttonTextColor value="#FFFFFF"/>
        <defaultActionButtonTextColor value="#FFFFFF"/>
        <actionButtonTextColor value="#FFFFFF"/>
        <actionButtonRolloverTextColor value="#FFFFFF"/>
        <buttonRolloverTextColor value="#2DD4BF"/>
        <radioCheckTextColor value="#FFFFFF"/>
        <groupTextColor value="#777777"/>
        <labelTextColor value="#FFFFFF"/>
        <toolTextColor value="#FFFFFF"/>
        <fontColor value="#FFFFFF"/>
        <monoColor value="#FFFFFF"/>

        <!-- Interactive / Accent (teal — unchanged) -->
        <highlightColor value="#0D9488"/>
        <highlightTextColor value="#FFFFFF"/>
        <activeColor value="#0D9488"/>
        <activeTextColor value="#FFFFFF"/>
        <activeBorderColor value="#3A3A3A"/>
        <checkedColor value="#0D9488"/>
        <linkColor value="#2DD4BF"/>
        <visitedLinkColor value="#5EEAD4"/>

        <!-- Inactive / Disabled -->
        <deactiveColor value="#2A2A2A"/>
        <deactiveTextColor value="#8892C0"/>
        <deactiveBorderColor value="#3A3A3A"/>
        <disableColor value="#8892C0"/>

        <!-- Light/Shadow (borders) -->
        <lightColor value="#2A2A2A"/>
        <lightBorderColor value="#3A3A3A"/>
        <shadowColor value="#3A3A3A"/>
        <darkShadowColor value="#777777"/>

        <!-- Fields -->
        <fieldColor value="#2A2A2A"/>
        <fieldTextColor value="#FFFFFF"/>
        <fieldRolloverTextColor value="#FFFFFF"/>

        <!-- Menus -->
        <menuColor value="#2A2A2A"/>
        <menuBarColor value="#2A2A2A"/>
        <menuBarRolloverColor value="#0D9488"/>
        <menuBorderColor value="#3A3A3A"/>
        <menuTextColor value="#FFFFFF"/>
        <menuBarTextColor value="#FFFFFF"/>
        <menuBarRolloverTextColor value="#FFFFFF"/>
        <menuBarHighlightTextColor value="#FFFFFF"/>
        <menuHighlightColor value="#0D9488"/>
        <menuHighlightTextColor value="#FFFFFF"/>

        <!-- Tabs -->
        <activeTabColor value="#2D3048"/>
        <inactiveTabColor value="#1A1A1A"/>
        <tabTextColor value="#FFFFFF"/>
        <tabRolloverTextColor value="#2DD4BF"/>
        <tabHighlightTextColor value="#2DD4BF"/>

        <!-- Help / Tooltip -->
        <helpColor value="#F5F5DC"/>
        <helpTextColor value="#1A1A1A"/>
    </style>

    <settings>
        <noActiveTabTextRaise value="true"/>
        <centeredTabs value="false"/>
        <listBoxEntryMargin value="5"/>
        <defaultFontSize value="9"/>
        <titleHeight value="16"/>
        <floatTitleHeight value="12"/>
        <listBoxPreviewDefaultLogicWidth value="15"/>
        <listBoxPreviewDefaultLogicHeight value="15"/>
    </settings>

    <pushbutton>
        <part value="Entire">
            <state enabled="true">
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="4" ry="4"/>
            </state>
            <state enabled="true" rollover="true">
                <rect stroke="#777777" fill="#2A2A2A" stroke-width="1" rx="4" ry="4"/>
            </state>
            <state enabled="true" pressed="true">
                <rect stroke="#0D9488" fill="#1A1A1A" stroke-width="1" rx="4" ry="4"/>
            </state>
            <state enabled="false">
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </pushbutton>

    <!-- ============================================================ -->
    <!-- Radio Buttons                                                 -->
    <!-- ============================================================ -->
    <radiobutton>
        <part value="Entire" width="20" height="20">
           <state enabled="true" pressed="false" button-value="true">
                <image source="tick-on.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="true">
                <image source="tick-on-pressed.svg" />
            </state>
            <state enabled="false" button-value="true">
                <image source="tick-on-disabled.svg" />
            </state>
            <state enabled="true" pressed="false" button-value="false">
                <image source="tick-off.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="false">
                <image source="tick-off-pressed.svg" />
            </state>
            <state enabled="false" button-value="false">
                <image source="tick-off-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </radiobutton>

    <!-- ============================================================ -->
    <!-- Checkboxes (Toggle switches)                                  -->
    <!-- ============================================================ -->
    <checkbox>
        <part value="Entire" width="36" height="24">
           <state enabled="true" pressed="false" button-value="true">
                <image source="switch-on.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="true">
                <image source="switch-on-pressed.svg" />
            </state>
            <state enabled="false" button-value="true">
                <image source="switch-on-disabled.svg" />
            </state>
            <state enabled="true" pressed="false" button-value="false">
                <image source="switch-off.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="false">
                <image source="switch-off-pressed.svg" />
            </state>
            <state enabled="false" button-value="false">
                <image source="switch-off-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </checkbox>

    <!-- ============================================================ -->
    <!-- Combo/List Boxes                                              -->
    <!-- ============================================================ -->
    <combobox>
        <part value="Entire">
            <state enabled="true">
                <external source="combobox.svg" />
            </state>
            <state enabled="false">
                <external source="combobox-disabled.svg" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="28" height="28">
            <state enabled="true">
                <image source="combobox-button.svg" />
            </state>
            <state enabled="false">
                <image source="combobox-button-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </combobox>

    <!-- ============================================================ -->
    <!-- Edit Boxes                                                    -->
    <!-- ============================================================ -->
    <editbox>
        <part value="Entire" height="24">
            <state enabled="true">
                <external source="common-rect.svg" />
            </state>
            <state enabled="false">
                <external source="common-rect-disabled.svg" />
            </state>
            <state focused="true">
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </editbox>

    <!-- ============================================================ -->
    <!-- List Boxes                                                    -->
    <!-- ============================================================ -->
    <listbox>
        <part value="Entire">
            <state enabled="true">
                <external source="combobox.svg" />
            </state>
            <state enabled="false">
                <external source="combobox-disabled.svg" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="28" height="28">
            <state enabled="true">
                <image source="combobox-button.svg" />
            </state>
            <state enabled="false">
                <image source="combobox-button-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </listbox>

    <!-- ============================================================ -->
    <!-- Spinbox                                                       -->
    <!-- ============================================================ -->
    <spinbox>
        <part value="Entire" orientation="decrease-edit-increase">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="32" height="22">
            <state enabled="true">
                <external source="spinbox-left.svg" />
            </state>
            <state enabled="true" pressed="true">
                <external source="spinbox-left-pressed.svg" />
            </state>
            <state enabled="false">
                <external source="spinbox-left-disabled.svg" />
            </state>
        </part>
        <part value="ButtonUp" width="32" height="22">
            <state enabled="true">
                <external source="spinbox-right.svg" />
            </state>
            <state enabled="true" pressed="true">
                <external source="spinbox-right-pressed.svg" />
            </state>
            <state enabled="false">
                <external source="spinbox-right-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </spinbox>

    <!-- ============================================================ -->
    <!-- Scrollbars (thin, minimal, no arrow buttons)                  -->
    <!-- ============================================================ -->
    <scrollbar>
        <part value="ThumbHorz">
            <state>
                <external source="scrollbar-horizontal.svg" />
            </state>
        </part>
        <part value="ThumbVert">
            <state>
                <external source="scrollbar-vertical.svg" />
            </state>
        </part>
        <part value="ButtonUp"/>
        <part value="ButtonDown"/>
        <part value="ButtonLeft"/>
        <part value="ButtonRight"/>
        <part value="TrackHorzLeft">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" />
            </state>
        </part>
        <part value="TrackHorzRight">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" />
            </state>
        </part>
        <part value="TrackVertUpper">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" />
            </state>
        </part>
        <part value="TrackVertLower">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" />
            </state>
        </part>
    </scrollbar>

    <!-- ============================================================ -->
    <!-- Slider                                                        -->
    <!-- ============================================================ -->
    <slider>
        <part value="Button">
            <state enabled="true">
                <image source="slider-button.svg" />
            </state>
            <state enabled="false">
                <image source="slider-button-disabled.svg" />
            </state>
        </part>
        <part value="TrackHorzLeft">
            <state enabled="true">
                <line stroke="#0D9488" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
            <state enabled="false">
                <line stroke="#3A3A3A" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="TrackHorzRight">
            <state>
                <line stroke="#3A3A3A" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="TrackVertUpper">
            <state enabled="true">
                <line stroke="#0D9488" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
            <state enabled="false">
                <line stroke="#3A3A3A" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
        <part value="TrackVertLower">
            <state>
                <line stroke="#3A3A3A" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
    </slider>

    <!-- ============================================================ -->
    <!-- Fixed Line (Separators)                                       -->
    <!-- ============================================================ -->
    <fixedline>
        <part value="SeparatorHorz">
            <state>
                <line stroke="#3A3A3A" fill="#3A3A3A" stroke-width="1" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="SeparatorVert">
            <state>
                <line stroke="#3A3A3A" fill="#3A3A3A" stroke-width="1" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
    </fixedline>

    <!-- ============================================================ -->
    <!-- Progress Bar                                                  -->
    <!-- ============================================================ -->
    <progress>
        <part value="Entire">
            <state>
                <rect stroke="#0D9488" fill="#0D9488" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </progress>

    <!-- ============================================================ -->
    <!-- Tab Items (with accent underline on selected)                 -->
    <!-- ============================================================ -->
    <tabitem>
        <part value="Entire" margin-width="4" height="26">
            <state selected="false" extra="first">
                <external source="tabitem-first.svg" />
            </state>
            <state selected="false" extra="middle">
                <external source="tabitem-middle.svg" />
            </state>
            <state selected="false" extra="last">
                <external source="tabitem-last.svg" />
            </state>
            <state selected="true" extra="first">
                <external source="tabitem-first-selected.svg" />
            </state>
            <state selected="true" extra="middle">
                <external source="tabitem-middle-selected.svg" />
            </state>
            <state selected="true" extra="last">
                <external source="tabitem-last-selected.svg" />
            </state>
        </part>
    </tabitem>

    <!-- ============================================================ -->
    <!-- Tab Header / Tab Pane / Tab Body                              -->
    <!-- ============================================================ -->
    <tabheader>
        <part value="Entire">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
    </tabheader>

    <tabpane>
        <part value="Entire">
            <state>
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
    </tabpane>

    <tabbody>
        <part value="Entire">
            <state>
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
    </tabbody>

    <!-- ============================================================ -->
    <!-- Window / Dialog Backgrounds                                   -->
    <!-- ============================================================ -->
    <windowbackground>
        <part value="BackgroundWindow">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
        <part value="BackgroundDialog">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
    </windowbackground>

    <!-- ============================================================ -->
    <!-- Frame (Group Boxes)                                           -->
    <!-- ============================================================ -->
    <frame>
        <part value="Border">
            <state>
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="6" ry="6"/>
            </state>
        </part>
    </frame>

    <!-- ============================================================ -->
    <!-- Toolbar                                                       -->
    <!-- ============================================================ -->
    <toolbar>
        <part value="DrawBackgroundHorz">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>

        <part value="DrawBackgroundVert">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>

        <part value="ThumbHorz">
            <state/>
        </part>

        <part value="ThumbVert">
            <state/>
        </part>

        <part value="SeparatorVert">
            <state>
                <line stroke="#3A3A3A" fill="#3A3A3A" stroke-width="1" x1="0.5" y1="0.15" x2="0.5" y2="0.85"/>
            </state>
        </part>

        <part value="SeparatorHorz">
            <state>
                <line stroke="#3A3A3A" fill="#3A3A3A" stroke-width="1" x1="0.15" y1="0.5" x2="0.85" y2="0.5"/>
            </state>
        </part>

        <!-- Toolbar buttons: do NOT define Button part here.
             VCL native rendering handles button backgrounds.
             Defining Button paints a rectangle OVER the icons. -->

    </toolbar>

    <!-- ============================================================ -->
    <!-- List Header                                                   -->
    <!-- ============================================================ -->
    <listnode/>
    <listnet/>

    <listheader>
         <part value="Button">
            <state>
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
        <part value="Arrow">
            <state extra="up">
                <image source="arrow-up.svg"/>
            </state>
            <state extra="down">
                <image source="arrow-down.svg"/>
            </state>
        </part>
    </listheader>

    <!-- ============================================================ -->
    <!-- Menu (empty = use defaults with style colors)                 -->
    <!-- ============================================================ -->
    <menubar>
        <part value="Entire">
            <state>
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0"/>
            </state>
        </part>
        <part value="MenuItem">
            <state selected="false">
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0"/>
            </state>
            <state selected="true">
                <rect stroke="#3A3A3A" fill="#1A3A38" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </menubar>

    <menupopup>
        <part value="Entire">
            <state>
                <rect stroke="#3A3A3A" fill="#1A1A1A" stroke-width="1" rx="6" ry="6"/>
            </state>
        </part>
        <part value="MenuItem">
            <state selected="false">
                <rect stroke="#1A1A1A" fill="#1A1A1A" stroke-width="0"/>
            </state>
            <state selected="true">
                <rect stroke="#0D9488" fill="#1A3A38" stroke-width="0" rx="4" ry="4"/>
            </state>
        </part>
        <part value="Separator">
            <state>
                <line stroke="#3A3A3A" stroke-width="1" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
    </menupopup>

    <tooltip>
        <part value="Entire">
            <state>
                <rect stroke="#3A3A3A" fill="#F5F5DC" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </tooltip>
</widgets>
