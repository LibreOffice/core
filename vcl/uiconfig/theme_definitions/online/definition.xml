<?xml version="1.0" encoding="UTF-8"?>

<!-- OfficeLabs Modern Theme (Light Mode)
     Accent: Teal #0D9488
     Surfaces: Near-white (#FAFAFA, #F5F5F5, #FFFFFF)
     Borders: Subtle (#D4D4D4, #E5E5E5)
     Text: Dark (#1A1A1A, #333333, #525252)
     Rounded corners (6px buttons, 15px toggles)
-->

<widgets>
    <style>
        <!-- Surfaces -->
        <faceColor value="#FAFAFA"/>
        <windowColor value="#FFFFFF"/>
        <dialogColor value="#FAFAFA"/>
        <dialogTextColor value="#1A1A1A"/>
        <workspaceColor value="#F0F0F0"/>

        <!-- Text -->
        <windowTextColor value="#1A1A1A"/>
        <buttonTextColor value="#333333"/>
        <defaultActionButtonTextColor value="#FFFFFF"/>
        <actionButtonTextColor value="#FFFFFF"/>
        <actionButtonRolloverTextColor value="#FFFFFF"/>
        <buttonRolloverTextColor value="#0D9488"/>
        <radioCheckTextColor value="#1A1A1A"/>
        <groupTextColor value="#525252"/>
        <labelTextColor value="#333333"/>
        <toolTextColor value="#333333"/>
        <fontColor value="#1A1A1A"/>
        <monoColor value="#1A1A1A"/>

        <!-- Interactive / Accent -->
        <highlightColor value="#0D9488"/>
        <highlightTextColor value="#FFFFFF"/>
        <activeColor value="#0D9488"/>
        <activeTextColor value="#FFFFFF"/>
        <activeBorderColor value="#D4D4D4"/>
        <checkedColor value="#0D9488"/>
        <linkColor value="#0D9488"/>
        <visitedLinkColor value="#0F766E"/>

        <!-- Inactive / Disabled -->
        <deactiveColor value="#E5E5E5"/>
        <deactiveTextColor value="#A3A3A3"/>
        <deactiveBorderColor value="#E5E5E5"/>
        <disableColor value="#A3A3A3"/>

        <!-- Light/Shadow (borders) -->
        <lightColor value="#FFFFFF"/>
        <lightBorderColor value="#E8E8E8"/>
        <shadowColor value="#D4D4D4"/>
        <darkShadowColor value="#A3A3A3"/>

        <!-- Fields -->
        <fieldColor value="#FFFFFF"/>
        <fieldTextColor value="#1A1A1A"/>
        <fieldRolloverTextColor value="#1A1A1A"/>

        <!-- Menus -->
        <menuColor value="#FFFFFF"/>
        <menuBarColor value="#FAFAFA"/>
        <menuBarRolloverColor value="#0D9488"/>
        <menuBorderColor value="#E8E8E8"/>
        <menuTextColor value="#1A1A1A"/>
        <menuBarTextColor value="#333333"/>
        <menuBarRolloverTextColor value="#FFFFFF"/>
        <menuBarHighlightTextColor value="#FFFFFF"/>
        <menuHighlightColor value="#0D9488"/>
        <menuHighlightTextColor value="#FFFFFF"/>

        <!-- Tabs -->
        <activeTabColor value="#FFFFFF"/>
        <inactiveTabColor value="#F5F5F5"/>
        <tabTextColor value="#525252"/>
        <tabRolloverTextColor value="#0D9488"/>
        <tabHighlightTextColor value="#0D9488"/>

        <!-- Help / Tooltip -->
        <helpColor value="#FFFBEB"/>
        <helpTextColor value="#1A1A1A"/>
    </style>

    <settings>
        <noActiveTabTextRaise value="true"/>
        <centeredTabs value="false"/>
        <listBoxEntryMargin value="8"/>
        <defaultFontSize value="10"/>
        <titleHeight value="18"/>
        <floatTitleHeight value="14"/>
        <listBoxPreviewDefaultLogicWidth value="16"/>
        <listBoxPreviewDefaultLogicHeight value="16"/>
    </settings>

    <!-- ============================================================ -->
    <!-- Push Buttons                                                  -->
    <!-- ============================================================ -->
    <pushbutton>
        <part value="Entire">
            <state enabled="true">
                <external source="pushbutton-default.svg" />
            </state>
            <state enabled="true" rollover="true">
                <external source="pushbutton-rollover.svg" />
            </state>
            <state enabled="true" pressed="true">
                <external source="pushbutton-pressed.svg" />
            </state>
            <state enabled="false">
                <external source="pushbutton-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </pushbutton>

    <!-- ============================================================ -->
    <!-- Radio Buttons                                                 -->
    <!-- ============================================================ -->
    <radiobutton>
        <part value="Entire" width="26" height="26">
           <state enabled="true" pressed="false" button-value="true">
                <image source="tick-on.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="true">
                <image source="tick-on-pressed.svg" />
            </state>
            <state enabled="false" button-value="true">
                <image source="tick-on-disabled.svg" />
            </state>
            <state enabled="true" pressed="false" button-value="false">
                <image source="tick-off.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="false">
                <image source="tick-off-pressed.svg" />
            </state>
            <state enabled="false" button-value="false">
                <image source="tick-off-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </radiobutton>

    <!-- ============================================================ -->
    <!-- Checkboxes (Toggle switches)                                  -->
    <!-- ============================================================ -->
    <checkbox>
        <part value="Entire" width="46" height="32">
           <state enabled="true" pressed="false" button-value="true">
                <image source="switch-on.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="true">
                <image source="switch-on-pressed.svg" />
            </state>
            <state enabled="false" button-value="true">
                <image source="switch-on-disabled.svg" />
            </state>
            <state enabled="true" pressed="false" button-value="false">
                <image source="switch-off.svg" />
            </state>
            <state enabled="true" pressed="true" button-value="false">
                <image source="switch-off-pressed.svg" />
            </state>
            <state enabled="false" button-value="false">
                <image source="switch-off-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </checkbox>

    <!-- ============================================================ -->
    <!-- Combo/List Boxes                                              -->
    <!-- ============================================================ -->
    <combobox>
        <part value="Entire">
            <state enabled="true">
                <external source="combobox.svg" />
            </state>
            <state enabled="false">
                <external source="combobox-disabled.svg" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="35" height="36">
            <state enabled="true">
                <image source="combobox-button.svg" />
            </state>
            <state enabled="false">
                <image source="combobox-button-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </combobox>

    <!-- ============================================================ -->
    <!-- Edit Boxes                                                    -->
    <!-- ============================================================ -->
    <editbox>
        <part value="Entire" height="32">
            <state enabled="true">
                <external source="common-rect.svg" />
            </state>
            <state enabled="false">
                <external source="common-rect-disabled.svg" />
            </state>
            <state focused="true">
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </editbox>

    <!-- ============================================================ -->
    <!-- List Boxes                                                    -->
    <!-- ============================================================ -->
    <listbox>
        <part value="Entire">
            <state enabled="true">
                <external source="combobox.svg" />
            </state>
            <state enabled="false">
                <external source="combobox-disabled.svg" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="35" height="36">
            <state enabled="true">
                <image source="combobox-button.svg" />
            </state>
            <state enabled="false">
                <image source="combobox-button-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus.svg" />
            </state>
        </part>
    </listbox>

    <!-- ============================================================ -->
    <!-- Spinbox                                                       -->
    <!-- ============================================================ -->
    <spinbox>
        <part value="Entire" orientation="decrease-edit-increase">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" />
            </state>
        </part>
        <part value="SubEdit">
            <state/>
        </part>
        <part value="ButtonDown" width="44" height="26">
            <state enabled="true">
                <external source="spinbox-left.svg" />
            </state>
            <state enabled="true" pressed="true">
                <external source="spinbox-left-pressed.svg" />
            </state>
            <state enabled="false">
                <external source="spinbox-left-disabled.svg" />
            </state>
        </part>
        <part value="ButtonUp" width="44" height="26">
            <state enabled="true">
                <external source="spinbox-right.svg" />
            </state>
            <state enabled="true" pressed="true">
                <external source="spinbox-right-pressed.svg" />
            </state>
            <state enabled="false">
                <external source="spinbox-right-disabled.svg" />
            </state>
        </part>
        <part value="Focus">
            <state>
                <external source="common-rect-focus-slim.svg" />
            </state>
        </part>
    </spinbox>

    <!-- ============================================================ -->
    <!-- Scrollbars (thin, minimal, no arrow buttons)                  -->
    <!-- ============================================================ -->
    <scrollbar>
        <part value="ThumbHorz">
            <state>
                <external source="scrollbar-horizontal.svg" />
            </state>
        </part>
        <part value="ThumbVert">
            <state>
                <external source="scrollbar-vertical.svg" />
            </state>
        </part>
        <part value="ButtonUp"/>
        <part value="ButtonDown"/>
        <part value="ButtonLeft"/>
        <part value="ButtonRight"/>
        <part value="TrackHorzLeft">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" />
            </state>
        </part>
        <part value="TrackHorzRight">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" />
            </state>
        </part>
        <part value="TrackVertUpper">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" />
            </state>
        </part>
        <part value="TrackVertLower">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" />
            </state>
        </part>
    </scrollbar>

    <!-- ============================================================ -->
    <!-- Slider                                                        -->
    <!-- ============================================================ -->
    <slider>
        <part value="Button">
            <state enabled="true">
                <image source="slider-button.svg" />
            </state>
            <state enabled="false">
                <image source="slider-button-disabled.svg" />
            </state>
        </part>
        <part value="TrackHorzLeft">
            <state enabled="true">
                <line stroke="#0D9488" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
            <state enabled="false">
                <line stroke="#D4D4D4" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="TrackHorzRight">
            <state>
                <line stroke="#E5E5E5" stroke-width="4" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="TrackVertUpper">
            <state enabled="true">
                <line stroke="#0D9488" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
            <state enabled="false">
                <line stroke="#D4D4D4" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
        <part value="TrackVertLower">
            <state>
                <line stroke="#E5E5E5" stroke-width="4" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
    </slider>

    <!-- ============================================================ -->
    <!-- Fixed Line (Separators)                                       -->
    <!-- ============================================================ -->
    <fixedline>
        <part value="SeparatorHorz">
            <state>
                <line stroke="#E8E8E8" fill="#E8E8E8" stroke-width="1" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
        <part value="SeparatorVert">
            <state>
                <line stroke="#E8E8E8" fill="#E8E8E8" stroke-width="1" x1="0.5" y1="0.0" x2="0.5" y2="1.0"/>
            </state>
        </part>
    </fixedline>

    <!-- ============================================================ -->
    <!-- Progress Bar                                                  -->
    <!-- ============================================================ -->
    <progress>
        <part value="Entire">
            <state>
                <rect stroke="#0D9488" fill="#0D9488" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </progress>

    <!-- ============================================================ -->
    <!-- Tab Items (with accent underline on selected)                 -->
    <!-- ============================================================ -->
    <tabitem>
        <part value="Entire" margin-width="8" height="32">
            <state selected="false" extra="first">
                <external source="tabitem-first.svg" />
            </state>
            <state selected="false" extra="middle">
                <external source="tabitem-middle.svg" />
            </state>
            <state selected="false" extra="last">
                <external source="tabitem-last.svg" />
            </state>
            <state selected="true" extra="first">
                <external source="tabitem-first-selected.svg" />
            </state>
            <state selected="true" extra="middle">
                <external source="tabitem-middle-selected.svg" />
            </state>
            <state selected="true" extra="last">
                <external source="tabitem-last-selected.svg" />
            </state>
        </part>
    </tabitem>

    <!-- ============================================================ -->
    <!-- Tab Header / Tab Pane / Tab Body                              -->
    <!-- ============================================================ -->
    <tabheader>
        <part value="Entire">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
    </tabheader>

    <tabpane>
        <part value="Entire">
            <state>
                <rect stroke="#E8E8E8" fill="#FFFFFF" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
    </tabpane>

    <tabbody>
        <part value="Entire">
            <state>
                <rect stroke="#E8E8E8" fill="#FFFFFF" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
    </tabbody>

    <!-- ============================================================ -->
    <!-- Window / Dialog Backgrounds                                   -->
    <!-- ============================================================ -->
    <windowbackground>
        <part value="BackgroundWindow">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
        <part value="BackgroundDialog">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>
    </windowbackground>

    <!-- ============================================================ -->
    <!-- Frame (Group Boxes)                                           -->
    <!-- ============================================================ -->
    <frame>
        <part value="Border">
            <state>
                <rect stroke="#E8E8E8" fill="#FFFFFF" stroke-width="1" rx="6" ry="6"/>
            </state>
        </part>
    </frame>

    <!-- ============================================================ -->
    <!-- Toolbar                                                       -->
    <!-- ============================================================ -->
    <toolbar>
        <part value="DrawBackgroundHorz">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>

        <part value="DrawBackgroundVert">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="0" ry="0"/>
            </state>
        </part>

        <part value="ThumbHorz">
            <state/>
        </part>

        <part value="ThumbVert">
            <state/>
        </part>

        <part value="SeparatorVert">
            <state>
                <line stroke="#E8E8E8" fill="#E8E8E8" stroke-width="1" x1="0.5" y1="0.15" x2="0.5" y2="0.85"/>
            </state>
        </part>

        <part value="SeparatorHorz">
            <state>
                <line stroke="#E8E8E8" fill="#E8E8E8" stroke-width="1" x1="0.15" y1="0.5" x2="0.85" y2="0.5"/>
            </state>
        </part>

        <part value="Button">
            <!-- Active/toggled toolbar button -->
            <state enabled="true" button-value="true">
                <rect stroke="#0D9488" fill="#F0FDFA" stroke-width="1" rx="6" ry="6"/>
            </state>
            <!-- Inactive toolbar button -->
            <state enabled="true" button-value="false">
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0" rx="6" ry="6"/>
            </state>
            <!-- Rollover toolbar button -->
            <state enabled="true" rollover="true">
                <rect stroke="#D4D4D4" fill="#F5F5F5" stroke-width="1" rx="6" ry="6"/>
            </state>
            <!-- Pressed toolbar button -->
            <state enabled="true" pressed="true">
                <rect stroke="#0D9488" fill="#CCFBF1" stroke-width="1" rx="6" ry="6"/>
            </state>
            <!-- Disabled toolbar button -->
            <state enabled="false">
                <rect stroke="#F5F5F5" fill="#F5F5F5" stroke-width="0" rx="6" ry="6"/>
            </state>
        </part>
    </toolbar>

    <!-- ============================================================ -->
    <!-- List Header                                                   -->
    <!-- ============================================================ -->
    <listnode/>
    <listnet/>

    <listheader>
         <part value="Button">
            <state>
                <rect stroke="#E8E8E8" fill="#FAFAFA" stroke-width="1" rx="0" ry="0"/>
            </state>
        </part>
        <part value="Arrow">
            <state extra="up">
                <image source="arrow-up.svg"/>
            </state>
            <state extra="down">
                <image source="arrow-down.svg"/>
            </state>
        </part>
    </listheader>

    <!-- ============================================================ -->
    <!-- Menu (empty = use defaults with style colors)                 -->
    <!-- ============================================================ -->
    <menubar>
        <part value="Entire">
            <state>
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0"/>
            </state>
        </part>
        <part value="MenuItem">
            <state selected="false">
                <rect stroke="#FAFAFA" fill="#FAFAFA" stroke-width="0"/>
            </state>
            <state selected="true">
                <rect stroke="#E5E5E5" fill="#F0FDFA" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </menubar>

    <menupopup>
        <part value="Entire">
            <state>
                <rect stroke="#E5E5E5" fill="#FFFFFF" stroke-width="1" rx="6" ry="6"/>
            </state>
        </part>
        <part value="MenuItem">
            <state selected="false">
                <rect stroke="#FFFFFF" fill="#FFFFFF" stroke-width="0"/>
            </state>
            <state selected="true">
                <rect stroke="#CCFBF1" fill="#F0FDFA" stroke-width="0" rx="4" ry="4"/>
            </state>
        </part>
        <part value="Separator">
            <state>
                <line stroke="#E8E8E8" stroke-width="1" x1="0.0" y1="0.5" x2="1.0" y2="0.5"/>
            </state>
        </part>
    </menupopup>

    <tooltip>
        <part value="Entire">
            <state>
                <rect stroke="#D4D4D4" fill="#FFFBEB" stroke-width="1" rx="4" ry="4"/>
            </state>
        </part>
    </tooltip>
</widgets>
