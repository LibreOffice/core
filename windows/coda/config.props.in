<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IncludePath>@POCOINCLUDE_WINDOWS@;@LOBUILDDIR_WINDOWS@\include;$(IncludePath)</IncludePath>
    <LibraryPath>@POCOLIB_WINDOWS@;$(LibraryPath)</LibraryPath>
    <LO_PATH>@LO_PATH@</LO_PATH>
    <APP_NAME>@APP_NAME@</APP_NAME>
    <APP_VENDOR>@VENDOR@</APP_VENDOR>
  </PropertyGroup>
  <!-- Run the clang-cl compiles through the ccache masquerade directory
       configure created. When CODA_CCACHE is empty the condition is false
       and the stock ClangCL toolset is used, so a build without ccache is
       unchanged. -->
  <PropertyGroup Condition="'@CODA_CCACHE@' != ''">
    <CLToolPath>@CODA_CCACHE@</CLToolPath>
    <CLToolExe>clang-cl.exe</CLToolExe>
  </PropertyGroup>
</Project>
