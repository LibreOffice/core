#: src/errormessages.js:22
msgid "No disk space left on server."
msgstr "ບໍ່ມີພື້ນທີ່ຫວ່າງໃນເຊີບເວີ."

#: src/errormessages.js:23
msgid ""
"The host URL is empty. The coolwsd server is probably misconfigured, please "
"contact the administrator."
msgstr ""
"URL ຂອງໂຮສຕ໌ຫວ່າງເປົ່າ. ເຊີບເວີ coolwsd ອາດຈະຖືກຕັ້ງຄ່າຜິດ, "
"ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບ."

#: src/errormessages.js:24
msgid ""
"This is an unsupported version of {productname}. To avoid the impression "
"that it is suitable for deployment in enterprises, this message appears "
"when more than {docs} documents or {connections} connections are in use "
"concurrently."
msgstr ""
"ນີ້ແມ່ນເວີຊັນຂອງ {productname} ທີ່ບໍ່ຮອງຮັບ. "
"ເພື່ອຫຼີກລ່ຽງຄວາມເຂົ້າໃຈຜິດວ່າມັນເໝາະສົມກັບການໃຊ້ໃນອົງກອນ, "
"ຂໍ້ຄວາມນີ້ຈະປະກົດຂຶ້ນເມື່ອມີເອກະສານຫຼາຍກວ່າ {docs} ຫຼື ການເຊື່ອມຕໍ່ຫຼາຍກວ່າ "
"{connections} ຖືກໃຊ້ງານພ້ອມກັນ."

#: src/errormessages.js:25
msgid "More information and support"
msgstr "ຂໍ້ມູນເພີ່ມເຕີມ ແລະ ການຊ່ວຍເຫຼືອ"

#: src/errormessages.js:26
msgid ""
"This service is limited to {0} documents, and {1} connections total by the "
"admin. This limit has been reached. Please try again later."
msgstr ""
"ການບໍລິການນີ້ຖືກຈຳກັດໃຫ້ມີ {0} ເອກະສານ ແລະ ທັງໝົດ {1} "
"ການເຊື່ອມຕໍ່ໂດຍຜູ້ເບິ່ງແຍງລະບົບ. ເຖິງຂີດຈຳກັດແລ້ວ. ກະລຸນາລອງໃໝ່ພາຍຫຼັງ."

#: src/errormessages.js:27
msgid ""
"Service is unavailable. Please try again later and report to your "
"administrator if the issue persists."
msgstr ""
"ບໍລິການບໍ່ສາມາດໃຊ້ງານໄດ້. ກະລຸນາລອງໃໝ່ພາຍຫຼັງ ແລະ "
"ລາຍງານໃຫ້ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານຊາບຫາກບັນຫາຍັງຄົງຢູ່."

#: src/errormessages.js:28
msgid ""
"Unauthorized WOPI host. Please try again later and report to your "
"administrator if the issue persists."
msgstr ""
"ໂຮສຕ໌ WOPI ບໍ່ໄດ້ຮັບອະນຸຍາດ. ກະລຸນາລອງໃໝ່ພາຍຫຼັງ ແລະ "
"ລາຍງານໃຫ້ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານຊາບຫາກບັນຫາຍັງຄົງຢູ່."

#: src/errormessages.js:29
msgid "Authorization error was: '{errormessage}'."
msgstr "ຂໍ້ຜິດພາດການອະນຸຍາດແມ່ນ: '{errormessage}'."

#: src/errormessages.js:30
msgid "Wrong or missing WOPISrc parameter, please contact support."
msgstr "ພາຣາມິເຕີ WOPISrc ຜິດ ຫຼື ບໍ່ມີ, ກະລຸນາຕິດຕໍ່ຝ່າຍຊ່ວຍເຫຼືອ."

#: src/errormessages.js:31
msgid ""
"Your session will expire in {time}. Please save your work and refresh the "
"session (or webpage) to continue. You might need to login again."
msgstr ""
"ເຊດຊັນຂອງທ່ານຈະໝົດອາຍຸໃນ {time}. ກະລຸນາບັນທຶກວຽກຂອງທ່ານ ແລະ ໂຫຼດເຊດຊັນ (ຫຼື "
"ໜ້າເວັບ) ໃໝ່ເພື່ອສືບຕໍ່. ທ່ານອາດຈະຕ້ອງເຂົ້າສູ່ລະບົບໃໝ່."

#: src/errormessages.js:32
msgid ""
"Your session has expired. Further changes to the document might not be "
"saved. Please refresh the session (or webpage) to continue. You might need "
"to login again."
msgstr ""
"ເຊດຊັນຂອງທ່ານໝົດອາຍຸແລ້ວ. ການປ່ຽນແປງເພີ່ມເຕີມໃນເອກະສານອາດຈະບໍ່ຖືກບັນທຶກ. "
"ກະລຸນາໂຫຼດເຊດຊັນ (ຫຼື ໜ້າເວັບ) ໃໝ່ເພື່ອສືບຕໍ່. ທ່ານອາດຈະຕ້ອງເຂົ້າສູ່ລະບົບໃໝ່."

#: src/errormessages.js:33
msgid ""
"Failed to load the document. Please ensure the file type is supported and "
"not corrupted, and try again."
msgstr ""
"ໂຫຼດເອກະສານລົ້ມເຫຼວ. ກະລຸນາກວດສອບໃຫ້ແນ່ໃຈວ່າປະເພດໄຟລ໌ຖືກຮອງຮັບ ແລະ ບໍ່"
"ເສຍຫາຍ, ແລ້ວລອງໃໝ່."

#: src/errormessages.js:34
msgid "Invalid link: '{url}'"
msgstr "ລິງກ໌ບໍ່ຖືກຕ້ອງ: '{url}'"

#: src/errormessages.js:35
msgid ""
"You are leaving the document. The following web page will open in a new "
"tab: "
msgstr "ທ່ານກຳລັງອອກຈາກເອກະສານ. ໜ້າເວັບຕໍ່ໄປນີ້ຈະເປີດໃນແຖບໃໝ່: "

#: src/errormessages.js:36
msgid ""
"Failed to load the document. This document is either malformed or is taking "
"more resources than allowed. Please contact the administrator."
msgstr ""
"ໂຫຼດເອກະສານລົ້ມເຫຼວ. ເອກະສານນີ້ອາດຈະມີຮູບແບບຜິດພາດ ຫຼື "
"ໃຊ້ຊັບພະຍາກອນຫຼາຍກວ່າທີ່ອະນຸຍາດ. ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບ."

#: src/errormessages.js:37
msgid "Cleaning up the document from the last session."
msgstr "ກຳລັງລ້າງຂໍ້ມູນເອກະສານຈາກເຊດຊັນທີ່ຜ່ານມາ."

#: src/errormessages.js:38
msgid ""
"We are in the process of cleaning up this document from the last session, "
"please try again later."
msgstr ""
"ພວກເຮົາກຳລັງຢູ່ໃນຂະບວນການລ້າງຂໍ້ມູນເອກະສານນີ້ຈາກເຊດຊັນທີ່ຜ່ານມາ, "
"ກະລຸນາລອງໃໝ່ພາຍຫຼັງ."

#: src/errormessages.js:39
msgid ""
"Your {productname} cluster appear to be mis-configured or scaling rapidly - "
"please contact your system administrator. Continuing with editing may "
"result in multiple users not seeing each other, conflicts in the document "
"storage and/or copy/paste problems. Expected serverId {0} for routeToken "
"{1} but connected to serverId {2}"
msgstr ""
"ຄລັສເຕີ {productname} ຂອງທ່ານເບິ່ງຄືວ່າຈະຖືກຕັ້ງຄ່າຜິດ ຫຼື ກຳລັງຂະຫຍາຍໂຕຢ່"
"າງໄວວາ - ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານ. "
"ການສືບຕໍ່ແກ້ໄຂອາດສົ່ງຜົນໃຫ້ຜູ້ໃຊ້ຫຼາຍຄົນບໍ່ເຫັນກັນ, ເກີດຄວາມຂັດແຍ້ງໃນບ່ອນເກັ"
"ບເອກະສານ ແລະ/ຫຼື ບັນຫາການສຳເນົາ/ວາງ. serverId ທີ່ຄາດໄວ້ແມ່ນ {0} ສຳລັບ "
"routeToken {1} ແຕ່ເຊື່ອມຕໍ່ກັບ serverId {2}"

#: src/errormessages.js:40
msgid ""
"Failed to establish socket connection or socket connection closed "
"unexpectedly. The reverse proxy might be misconfigured, please contact the "
"administrator. For more info on proxy configuration please checkout https://"
"sdk.collaboraonline.com/docs/installation/Proxy_settings.html"
msgstr ""
"ສ້າງການເຊື່ອມຕໍ່ socket ລົ້ມເຫຼວ ຫຼື ການເຊື່ອມຕໍ່ socket ປິດລົງໂດຍບໍ່ຄາດຄິດ. "
"reverse proxy ອາດຈະຖືກຕັ້ງຄ່າຜິດ, ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບ. "
"ສຳລັບຂໍ້ມູນເພີ່ມເຕີມກ່ຽວກັບການຕັ້ງຄ່າ proxy ກະລຸນາເບິ່ງທີ່ https://sdk."
"collaboraonline.com/docs/installation/Proxy_settings.html"

#: src/errormessages.js:41
msgid ""
"Failed to establish socket connection or socket connection closed "
"unexpectedly."
msgstr ""
"ສ້າງການເຊື່ອມຕໍ່ socket ລົ້ມເຫຼວ ຫຼື ການເຊື່ອມຕໍ່ socket ປິດລົງໂດຍບໍ່ຄາດຄິດ."

#: src/errormessages.js:44
msgid "Failed to load document."
msgstr "ໂຫຼດເອກະສານລົ້ມເຫຼວ."

#: src/errormessages.js:45
msgid "Save failed due to no disk space left. Document will now be read-only."
msgstr ""
"ບັນທຶກລົ້ມເຫຼວເນື່ອງຈາກບໍ່ມີພື້ນທີ່ຫວ່າງ. "
"ເອກະສານຈະເປັນແບບອ່ານເທົ່ານັ້ນຕອນນີ້."

#: src/errormessages.js:46
msgid ""
"The document is too large or no disk space left to save. Document will now "
"be read-only."
msgstr ""
"ເອກະສານໃຫຍ່ເກີນໄປ ຫຼື ບໍ່ມີພື້ນທີ່ຫວ່າງເພື່ອບັນທຶກ. "
"ເອກະສານຈະເປັນແບບອ່ານເທົ່ານັ້ນຕອນນີ້."

#: src/errormessages.js:47
msgid ""
"Document cannot be saved due to expired session, please reopen the document "
"to continue."
msgstr ""
"ບໍ່ສາມາດບັນທຶກເອກະສານໄດ້ເນື່ອງຈາກເຊດຊັນໝົດອາຍຸ, "
"ກະລຸນາເປີດເອກະສານໃໝ່ເພື່ອສືບຕໍ່."

#: src/errormessages.js:48
msgid "Document cannot be saved."
msgstr "ບໍ່ສາມາດບັນທຶກເອກະສານໄດ້."

#: src/errormessages.js:49
msgid "Document cannot be renamed."
msgstr "ບໍ່ສາມາດປ່ຽນຊື່ເອກະສານໄດ້."

#: src/errormessages.js:53
msgid ""
"Failed to read document from storage, please try to load the document again."
msgstr "ອ່ານເອກະສານຈາກບ່ອນເກັບລົ້ມເຫຼວ, ກະລຸນາລອງໂຫຼດເອກະສານໃໝ່."

#: src/errormessages.js:54
msgid ""
"Save failed due to no storage space left. The document will now be read-"
"only. Please make sure enough disk space is available and try to save again."
msgstr ""
"ບັນທຶກລົ້ມເຫຼວເນື່ອງຈາກບໍ່ມີພື້ນທີ່ເກັບຂໍ້ມູນ. "
"ເອກະສານຈະເປັນແບບອ່ານເທົ່ານັ້ນຕອນນີ້. "
"ກະລຸນາກວດສອບໃຫ້ແນ່ໃຈວ່າມີພື້ນທີ່ຫວ່າງພຽງພໍ ແລະ ລອງບັນທຶກໃໝ່."

#: src/errormessages.js:55
msgid ""
"Save failed because the document is too large or exceeds the remaining "
"storage space. The document will now be read-only but you may still "
"download it now to preserve a copy locally."
msgstr ""
