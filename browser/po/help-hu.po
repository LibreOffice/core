msgstr ""
"<kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Nyílbillentyűk</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:104-152
