msgid "Moves one sheet to the left."
msgstr "Verschiebt ein Tabellenblatt nach links."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:152-93
msgid ""
"<kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Page Up</kbd>"
msgstr ""
"<kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Bild auf</kbd>"

