#: html/cool-help.html%2Bdiv.div.div.table.tr.td:128-38
msgid ""
"Insert new paragraph directly before or after a section, or before a table"
msgstr ""
"Einen neuen Absatz direkt vor oder nach einem Bereich oder vor einer Tabelle "
"einfügen"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:128-139
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:129-175
