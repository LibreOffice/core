msgstr "{0} ընտրված է"

#: src/layer/marker/A11yTextInput.js:306
msgid "Has text: "
msgstr "Պարունակում է տեքստ: "

#: src/layer/marker/A11yTextInput.js:311
msgid "{0} unselected"
msgstr "{0} ապաընտրված է"

#: src/layer/marker/A11yTextInput.js:315
msgid "{0} deleted"
msgstr "{0} ջնջված"

