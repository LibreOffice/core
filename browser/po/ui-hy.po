msgid "Clipboard area"
msgstr "Սեղմատախտակի տարածք"

#: src/layer/marker/TextInput.js:481
msgid "Screen reader support for text content is disabled. "
msgstr "Տեքստային բովանդակության էկրանի ընթերցիչի աջակցությունն անջատված է։ "

#: src/layer/marker/TextInput.js:482
msgid "You need to enable it both at server level and in the UI. "
msgstr "Դուք պետք է այն միացնեք և՛ սերվերի մակարդակում, և՛ Օգտ․ միջ-ում։ "

#: src/layer/marker/TextInput.js:483
msgid "Look for the accessibility section in coolwsd.xml for server setting. "
msgstr ""
"Սերվերի կարգավորումների համար հասանելիության բաժինը փնտրեք coolwsd.xml -ում։ "

#: src/layer/marker/TextInput.js:484
msgid "Also check the voice over toggle under {parentControl}."
msgstr "Ստուգեք նաև {parentControl}-ի ներքո հնչյունավորման անջատիչը։"

#: src/layer/marker/TextInput.js:486
msgid "the Help tab"
msgstr "«Օգնություն» ներդիրը"

#: src/layer/marker/TextInput.js:486
msgid "the View menu"
msgstr "«Դիտել» ընտրացանկը"

#: src/layer/tile/CanvasTileLayer.js:458
msgid "Online Editor"
msgstr "Առցանց խմբագրիչ"

#: src/layer/tile/CanvasTileLayer.js:1553
msgid "Functions"
msgstr "Ֆունկցիաներ"

#: src/layer/tile/CanvasTileLayer.js:1839
msgid "Named Range"
msgstr "Անվանված միջակայք"

#: src/layer/tile/CanvasTileLayer.js:3680
