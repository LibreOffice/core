">+</span><kbd>D</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>D</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:119-38
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:170-38
msgid "Insert comment"
msgstr "Vložiť poznámku"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:119-79
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:170-79
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>C</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>C</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:121-38
msgid "Insert soft hyphen"
msgstr "Vložiť voliteľné rozdelenie"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:121-83
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>-</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>-</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:122-38
msgid "Insert non-breaking hyphen"
msgstr "Vložiť nezalomiteľný spojovník"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:122-91
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>-</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>-</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:124-38
msgid "Insert non-breaking space"
msgstr "Vložiť nezalomiteľnú medzeru"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:124-90
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Space</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Medzerník</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:125-38
msgid "Insert line break"
msgstr "Zalomiť riadok"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:125-82
msgid ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"
msgstr ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:126-38
msgid "Manual page break"
msgstr "Zalomiť stranu"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:126-82
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:254-98
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:319-105
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:127-38
msgid "Column break (in multicolumnar text)"
msgstr "Zalomiť stĺpec vo viacstĺpcových textoch"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:127-101
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:128-38
msgid ""
"Insert new paragraph directly before or after a section, or before a table"
msgstr "Vložiť nový odsek priamo pred alebo za sekciou alebo pred tabuľkou"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:128-139
#: html/cool-help.html%2Bdiv.div.div.table.tr.td:129-175
msgid ""
"<kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"
msgstr ""
"<kbd>Alt</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Enter</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:129-38
msgid ""
"Insert new paragraph without numbering inside a list. Does not work when the "
"cursor is at the end of the list."
msgstr ""
"Vloží nečíslovaný odsek vo vnútri číslovaného zoznamu. Nespraví nič na konci "
"zoznamu."

#: html/cool-help.html%2Bdiv.div.div.h2:135-9
msgid "Navigating in Spreadsheets"
msgstr "Navigácia v hárkoch"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:137-38
msgid "Moves the cursor to the first cell in the sheet (A1)."
msgstr "Presunie kurzor na prvú bunku v hárku (A1)."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:138-38
msgid "Moves the cursor to the last cell on the sheet that contains data."
msgstr "Presunie kurzor na poslednú bunku v hárku, ktorá obsahuje údaje."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:139-38
msgid "Moves the cursor to the first cell of the current row."
msgstr "Presunie kurzor na prvú bunku aktuálneho riadka."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:140-38
msgid "Moves the cursor to the last cell of the current row."
msgstr "Presunie kurzor na poslednú bunku aktuálneho riadka."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:141-38
msgid ""
"Selects cells from the current cell to the first cell of the current row."
msgstr "Označí bunky od aktuálnej bunky po prvú bunku aktuálneho riadku."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:142-38
msgid ""
"Selects cells from the current cell to the last cell of the current row."
msgstr "Označí bunky od aktuálnej bunky po poslednú bunku aktuálneho riadku."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:143-38
msgid ""
"Selects cells from the current cell up to one page in the current column or "
"extends the existing selection one page up."
msgstr ""
"Označí bunky od aktuálnej bunky o jednu stranu vyššie v aktuálnom stĺpci "
"alebo rozšíri existujúci výber o jednu stranu nahor."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:143-184
msgid ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Page Up</kbd>"
msgstr ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Stránka Nahor</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:144-38
msgid ""
"Selects cells from the current cell down to one page in the current column "
"or extends the existing selection one page down."
msgstr ""
"Označí bunky od aktuálnej bunky o jednu stranu nižšie v aktuálnom stĺpci "
"alebo rozšíri existujúci výber o jednu stranu nadol."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:144-188
msgid ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Page Down</kbd>"
msgstr ""
"<kbd>Shift</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Stránka Nadol</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:145-38
msgid ""
"Moves the cursor to the left edge of the current data range. If the column "
"to the left of the cell that contains the cursor is empty, the cursor moves "
"to the next column to the left that contains data"
msgstr ""
"Presunie kurzor na ľavý okraj aktuálneho rozsahu údajov. Ak je stĺpec naľavo "
"od bunky s kurzorom prázdny, kurzor sa presunie do najbližšieho stĺpca "
"naľavo, ktorý obsahuje údaje"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:145-265
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Left Arrow</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Šípka doľava</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:146-38
msgid ""
"Moves the cursor to the right edge of the current data range. If the column "
"to the right of the cell that contains the cursor is empty, the cursor moves "
"to the next column to the right that contains data."
msgstr ""
"Presunie kurzor na pravý okraj aktuálneho rozsahu údajov. Ak je stĺpec "
"napravo od bunky s kurzorom prázdny, kurzor sa presunie do najbližšieho "
"stĺpca napravo, ktorý obsahuje údaje."

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:146-269
msgid ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
"span><kbd>Right Arrow</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\">+</"
