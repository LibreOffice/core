"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Del</kbd>"
msgstr ""
"<kbd>Ctrl</kbd><span class=\"kbd--plus\" aria-hidden=\"true\""
">+</span><kbd>Supr</kbd>"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:91-38
msgid "Delete to beginning of sentence"
msgstr "Eliminar hasta el principio de una frase"

#: html/cool-help.html%2Bdiv.div.div.table.tr.td:91-96
