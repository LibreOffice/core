+			return;
+		}
+		MappingHeader::Process* current = &sMem->process[sMem->currentProcess];
+
+		// Deliver
+		for (unsigned n = 0; n < sMem->processes; ++n)
+		{
+			MappingHeader::Process* p = &sMem->process[n];
+			if (!(p->flags & MappingHeader::FLAG_ACTIVE))
+				continue;
+
+			if (p->id == processId)
