<?xml version="1.0" encoding="UTF-8"?>
<interface domain="sw">
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkBox" id="ChatPanel">
    <property name="visible">True</property>
    <property name="can_focus">False</property>
    <property name="orientation">vertical</property>
    <property name="spacing">4</property>
    <property name="vexpand">True</property>

    <!-- Status Label -->
    <child>
      <object class="GtkLabel" id="status_label">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="label" translatable="yes">OfficeLabs AI - Ready</property>
        <property name="xalign">0</property>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>

    <!-- Quick Actions Row 1: Clean, Review, Summary, Adapt -->
    <child>
      <object class="GtkBox" id="quick_actions_row1">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">2</property>
        <property name="homogeneous">True</property>
        <child>
          <object class="GtkButton" id="clean_button">
            <property name="label" translatable="yes">Clean</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Clean document: fix spacing, formatting issues</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="review_button">
            <property name="label" translatable="yes">Review</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Review: grammar, spelling, punctuation errors</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="summarize_button">
            <property name="label" translatable="yes">Summary</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Summarize selected text or entire document</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="adapt_button">
            <property name="label" translatable="yes">Adapt</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Adapt text: change tone, formality, style</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>

    <!-- Quick Actions Row 2: Improve, Translate, Expand, Condense -->
    <child>
      <object class="GtkBox" id="quick_actions_row2">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">2</property>
        <property name="homogeneous">True</property>
        <child>
          <object class="GtkButton" id="improve_button">
            <property name="label" translatable="yes">Improve</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Improve text clarity and quality</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="translate_button">
            <property name="label" translatable="yes">Translate</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Translate selected text</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="expand_button">
            <property name="label" translatable="yes">Expand</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Expand text with more details</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="condense_button">
            <property name="label" translatable="yes">Condense</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Make text shorter and more concise</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">2</property>
      </packing>
    </child>

    <!-- Chat History -->
    <child>
      <object class="GtkScrolledWindow">
        <property name="visible">True</property>
        <property name="can_focus">True</property>
        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
        <property name="height_request">700</property>
        <property name="shadow_type">in</property>
        <child>
          <object class="GtkTextView" id="chat_history">
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="editable">False</property>
            <property name="wrap_mode">word</property>
            <property name="top_margin">4</property>
            <property name="left_margin">4</property>
            <property name="right_margin">4</property>
            <property name="bottom_margin">4</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">3</property>
      </packing>
    </child>

    <!-- Action Buttons Row: Insert, Replace, Reset -->
    <child>
      <object class="GtkBox" id="action_row">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">4</property>
        <property name="homogeneous">True</property>
        <child>
          <object class="GtkButton" id="insert_button">
            <property name="label" translatable="yes">Insert</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Insert AI response at cursor</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="replace_button">
            <property name="label" translatable="yes">Replace</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Replace selection with AI response</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="reset_button">
            <property name="label" translatable="yes">Reset</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Clear chat and start fresh</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">4</property>
      </packing>
    </child>

    <!-- Revert Controls Row (Phase 2.5) -->
    <child>
      <object class="GtkBox" id="revert_row">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">4</property>
        <property name="homogeneous">True</property>
        <child>
          <object class="GtkButton" id="revert_all_button">
            <property name="label" translatable="yes">Revert All</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="sensitive">False</property>
            <property name="tooltip_text" translatable="yes">Undo all AI edits in this session</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="accept_all_button">
            <property name="label" translatable="yes">Accept All</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="sensitive">False</property>
            <property name="tooltip_text" translatable="yes">Accept all AI edits and clear history</property>
          </object>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">5</property>
      </packing>
    </child>

    <!-- Selection Context Badge (shows selected text) -->
    <child>
      <object class="GtkBox" id="selection_context_box">
        <property name="visible">False</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">4</property>
        <child>
          <object class="GtkLabel" id="selection_icon">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="label">📝</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object class="GtkLabel" id="selection_context_label">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="label">No selection</property>
            <property name="ellipsize">end</property>
            <property name="max_width_chars">40</property>
            <property name="xalign">0</property>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">1</property>
          </packing>
        </child>
        <child>
          <object class="GtkButton" id="clear_selection_button">
            <property name="label" translatable="yes">✕</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Clear selection context</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">2</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">6</property>
      </packing>
    </child>

    <!-- Input Row with @ button (at bottom) -->
    <child>
      <object class="GtkBox" id="input_row">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">4</property>
        <child>
          <object class="GtkButton" id="at_ref_button">
            <property name="label" translatable="yes">@</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="tooltip_text" translatable="yes">Insert @ reference: @selection, @document, @table1, @image1, @section1</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">False</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object class="GtkEntry" id="input_field">
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="hexpand">True</property>
            <property name="placeholder_text" translatable="yes">What do you want to do with the selection?</property>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">1</property>
          </packing>
        </child>
        <child>
          <object class="GtkButton" id="send_button">
            <property name="label" translatable="yes">Send</property>
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="receives_default">True</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">2</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">7</property>
      </packing>
    </child>
  </object>

</interface>
